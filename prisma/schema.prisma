// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Toko {
    id String @id @default(uuid())
    namaToko String
    logoToko String?
    logoTokoId String?
    alamat String
    noTelp String
    SubscribeTime DateTime
    User User[]
    Produk Produk[]
    Member Member[]
    Pengeluaran UangKeluar[]
    ServiceHP ServiceHP[]
    SparepartServiceHP SparepartServiceHP[]
    Transaksi Transaksi[]
    ItemsTransaksi ItemsTransaksi[]
    Log Log[]
    JualanHarian JualanHarian[]
    Keuntungan Keuntungan[]
    DataMember DataMember[]
    KlaimGaransi KlaimGaransi[]
    ItemKlaimGaransi ItemKlaimGaransi[]
    TransaksiVoucherHarian TransaksiVoucherHarian[]
    KejadianTakTerduga KejadianTakTerduga[]
    isActive Boolean @default(true)   // ✅ TAMBAHAN
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt

}

model Keuntungan {
  id                       String   @id @default(uuid())
  idToko                   String
  tanggal                  DateTime

  keuntunganTransaksi      BigInt   @default(0)
  keuntunganVoucherHarian  BigInt   @default(0)
  keuntunganAcc            BigInt   @default(0)
  keuntunganSparepart      BigInt   @default(0)
  keuntunganService        BigInt   @default(0)
  keuntunganGrosirVoucher  BigInt   @default(0)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  Toko                     Toko     @relation(fields: [idToko], references: [id])

  @@unique([idToko, tanggal])
}

model User {
    id String @id @default(uuid())
    nama String
    email String @unique
    password String
    role String
    penempatan String?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    idToko String
    isActive Boolean @default(true)  
    TransaksiVoucher TransaksiVoucherHarian[]
    Transaksi Transaksi[]
    JualanHarian JualanHarian[]
    ServiceHP ServiceHP[]
    Toko          Toko @relation(fields: [idToko], references: [id])

}

model Member {
    id String @id @default(uuid())
    nama String
    noTelp String @unique
    kodeMember String @unique
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    JualanHarian JualanHarian[]
    Transaksi Transaksi[]
    ServiceHP ServiceHP[]
    DataMember DataMember[]
    TransaksiVoucherHarian TransaksiVoucherHarian[]

    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])
}

model DataMember {
      id String @id @default(uuid())
      idToko String
      nama String
      nomor String
      idMember String?
      Member        Member? @relation(fields: [idMember], references: [id])
      Toko          Toko @relation(fields: [idToko], references: [id])

}

model Produk {
  id String @id @default(uuid())
  nama String
  kategori String
  sub_kategori String?
  brand String
  stok Int? @default(999999)
  hargaModal Int
  hargaGrosir Int?
  hargaEceran Int
  terjual Int? @default(0)
  penempatan String
  ItemTransaksi ItemsTransaksi[]
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  TransaksiVoucherHarian TransaksiVoucherHarian[]
  SparepartServiceHP SparepartServiceHP[]
  ItemKlaimGaransi ItemKlaimGaransi[]
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  isActive Boolean @default(true)   // ✅ TAMBAHAN
}

model TransaksiVoucherHarian {
  id String @id @default(uuid())
  idUser String?
  idProduk String
  idMember String?
  keuntungan Int
  Produk Produk @relation(fields: [idProduk], references: [id])
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  Member        Member? @relation(fields: [idMember], references: [id])
    User          User? @relation(fields: [idUser], references: [id])

}

model Transaksi {
  id String @id @default(uuid())
  idUser String?
  namaPembeli String?
  totalHarga Int
  tanggal DateTime
  type String
  keuntungan Int?
  status String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  items ItemsTransaksi[]
  idMember String?
  Member          Member? @relation(fields: [idMember], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])
  User          User? @relation(fields: [idUser], references: [id])

}



model JualanHarian {
      id String @id @default(uuid())
      idUser String?
      kategori String
      nominal Int?
      tanggal DateTime
      createdAt DateTime? @default(now())
      updatedAt DateTime? @updatedAt
      deletedAt DateTime?
      idMember String?
      Member          Member? @relation(fields: [idMember], references: [id])
      idToko String
      User          User? @relation(fields: [idUser], references: [id])
      Toko          Toko @relation(fields: [idToko], references: [id])
}


enum StatusServis {
  Pending
  Proses
  Selesai
  Gagal
}

enum StatusAmbil {
  BelumDiambil
  SudahDiambil
}


model ServiceHP {
  id            String   @id @default(uuid())

  idUser        String?
  User          User?    @relation(fields: [idUser], references: [id])

  idToko        String
  Toko          Toko     @relation(fields: [idToko], references: [id])

  idMember      String?
  Member        Member?  @relation(fields: [idMember], references: [id])

  brandHP       String
  keterangan    String
  tanggal       DateTime
  namaPelangan  String?
  noHP          String

  // 🔥 STATUS DIPISAH
  statusServis  StatusServis
  statusAmbil   StatusAmbil  @default(BelumDiambil)
  klaimGaransi KlaimGaransi[]
  itemKlaimGaransi ItemKlaimGaransi[]
  // 💰 KEUANGAN
  hargaSparePart Int?
  biayaJasa      Int
  keuntungan     Int

  // 🔧 RELASI
  Sparepart     SparepartServiceHP[]

  // 🛡️ GARANSI
  garansiMulai   DateTime?
  garansiBerakhir DateTime?

  // 📦 PENGAMBILAN
  tanggalAmbil   DateTime?

  // 🕒 SYSTEM
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model KlaimGaransi {
  id String @id @default(uuid())
  idToko        String
  idService     String
  keterangan String?
  item  ItemKlaimGaransi[]
  ServiceHP          ServiceHP     @relation(fields: [idService], references: [id])
  Toko          Toko     @relation(fields: [idToko], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model ItemKlaimGaransi {
  id String @id @default(uuid())
  idToko        String
  idService     String
  idProduct     String?
  idKlaimGaransi String
  quantityProduct Int
  keterangan String?
  ServiceHP          ServiceHP     @relation(fields: [idService], references: [id])
  Toko          Toko     @relation(fields: [idToko], references: [id])
  Product        Produk?     @relation(fields: [idProduct], references: [id])
  KlaimGaransi        KlaimGaransi     @relation(fields: [idKlaimGaransi], references: [id])

}

model ItemsTransaksi {
  id String @id @default(uuid())
  idTransaksi String
  idProduk String
  quantity Int
  tanggal DateTime?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  deletedAt DateTime?
  Transaksi Transaksi @relation(fields: [idTransaksi], references: [id])
  Produk Produk @relation(fields: [idProduk], references: [id])
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}


model SparepartServiceHP {
    id String @id @default(uuid())
    idServiceHP String
    idProduk String
    quantity Int
    tanggal DateTime?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    deletedAt DateTime?
    ServiveHP ServiceHP  @relation(fields: [idServiceHP], references: [id])
    Produk Produk  @relation(fields: [idProduk], references: [id])
    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])
}

model UangKeluar {
  id String @id @default(uuid())
  keterangan String
  tanggal DateTime
  jumlah Int
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  idToko String
  Toko          Toko @relation(fields: [idToko], references: [id])

}


model Log {
    id String @id @default(uuid())
    kategori String
    keterangan String
    nama String
    nominal Int?
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])

}


model KejadianTakTerduga {
    id String @id @default(uuid())
    idToko String
    Toko          Toko @relation(fields: [idToko], references: [id])
    nominal Int
    keterangan String
    createdAt DateTime? @default(now())
    updatedAt DateTime? @updatedAt
}